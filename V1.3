slMaLen      = input.int(50, "Custom MA Length", minval=1, group=gp_sltp)

atrLen       = input.int(14, "ATR Length", minval=1, group=gp_sltp)
atrMult      = input.float(1.5, "ATR Multiplier", minval=0.1, step=0.1, group=gp_sltp)

lbLen        = input.int(10, "Candle Lookback Length", minval=1, group=gp_sltp)
lbMargin     = input.float(0.5, "Candle Margin (%)", minval=0.0, step=0.1, group=gp_sltp, tooltip="Margin percentage of price to add/subtract from the lowest low / highest high")

// =============================================================================
// HELPER FUNCTIONS
// =============================================================================
getMA(type, length) =>
    float ma = na
    if type == "SMA"
        ma := ta.sma(close, length)
    else if type == "EMA"
        ma := ta.ema(close, length)
    else if type == "WMA"
        ma := ta.wma(close, length)
    else if type == "VWAP"
        ma := nz(volume) == 0 ? ta.sma(hlc3, length) : ta.vwma(hlc3, length)
    else if type == "Anchored VWAP"
        ma := ta.vwap
    else if type == "HMA"
        ma := ta.hma(close, length)
    ma

is_candle_wickless(o, h, l, c, avgRatio) =>
    body_val = math.abs(c - o)
    topWick = h - math.max(o, c)
    bottomWick = math.min(o, c) - l
    totalWick = topWick + bottomWick
    
    ratio = body_val / (totalWick == 0 ? syminfo.mintick : totalWick)
    isWickless = ratio > (avgRatio * strictnessMult)
    
    bullishWickless = isWickless and (c > o)
    bearishWickless = isWickless and (c < o)
    
    [bullishWickless, bearishWickless]

// VOLUME PROFILE: Calculate rolling LVN
f_rolling_lvn(int len, int rows, float currentPrice, bool isLong) =>
    float hi = ta.highest(high, len)
    float lo = ta.lowest(low, len)
    float rLvnPrice = na
    
    if not na(hi) and not na(lo)
        float step_val = hi == lo ? 0.0001 : (hi - lo) / rows
        float[] rVolumes = array.new_float(rows, 0.0)
        
        for i = 0 to len - 1
            float barVol = nz(volume[i]) == 0 ? 1.0 : nz(volume[i])
            float barHigh = high[i]
            float barLow = low[i]
            float barClose = close[i]
            
            if barHigh == barLow
                int binIdx = math.min(rows - 1, math.max(0, math.floor((barClose - lo) / step_val)))
                array.set(rVolumes, binIdx, array.get(rVolumes, binIdx) + barVol)
            else
                for j = 0 to rows - 1
                    float binMin = lo + j * step_val
                    float binMax = binMin + step_val
                    float overlapMin = math.max(barLow, binMin)
                    float overlapMax = math.min(barHigh, binMax)
                    if overlapMax > overlapMin
                        float proportion = (overlapMax - overlapMin) / (barHigh - barLow)
                        array.set(rVolumes, j, array.get(rVolumes, j) + barVol * proportion)
                        
        float totalVol = 0.0
        for j = 0 to rows - 1
            totalVol += array.get(rVolumes, j)
        float avgVol = totalVol / rows
        
        float closestLvnPrice = na
        float minDistance = 9999999.9
        
        for j = 0 to rows - 1
            float v = array.get(rVolumes, j)
            float binPrice = lo + j * step_val + (step_val / 2.0)
            
            if v < avgVol * 0.75 // significantly lower than average
                if isLong and binPrice < currentPrice
                    float dist = currentPrice - binPrice
                    if dist < minDistance
                        minDistance := dist
                        closestLvnPrice := binPrice
                else if not isLong and binPrice > currentPrice
                    float dist = binPrice - currentPrice
                    if dist < minDistance
                        minDistance := dist
                        closestLvnPrice := binPrice
                        
        rLvnPrice := closestLvnPrice
    rLvnPrice

// VOLUME PROFILE: Calculate rolling POC
f_rolling_poc(int len, int rows) =>
    float hi = ta.highest(high, len)
    float lo = ta.lowest(low, len)
    float rPocPrice = na
    
    if not na(hi) and not na(lo)
        float step_val = hi == lo ? 0.0001 : (hi - lo) / rows
        float[] rVolumes = array.new_float(rows, 0.0)
        
        for i = 0 to len - 1
            // Fallback to 1.0 if volume is 0 so it doesn't break on Forex/CFDs
            float barVol = nz(volume[i]) == 0 ? 1.0 : nz(volume[i])
            float barHigh = high[i]
            float barLow = low[i]
            float barClose = close[i]
            
            if barHigh == barLow
                int binIdx = math.min(rows - 1, math.max(0, math.floor((barClose - lo) / step_val)))
                array.set(rVolumes, binIdx, array.get(rVolumes, binIdx) + barVol)
            else
                for j = 0 to rows - 1
                    float binMin = lo + j * step_val
                    float binMax = binMin + step_val
                    float overlapMin = math.max(barLow, binMin)
                    float overlapMax = math.min(barHigh, binMax)
                    if overlapMax > overlapMin
                        float proportion = (overlapMax - overlapMin) / (barHigh - barLow)
                        array.set(rVolumes, j, array.get(rVolumes, j) + barVol * proportion)
                        
        float maxVol = 0.0
        int pocBinIdx = 0
        for j = 0 to rows - 1
            float v = array.get(rVolumes, j)
            if v > maxVol
                maxVol := v
                pocBinIdx := j
                
        rPocPrice := lo + pocBinIdx * step_val + (step_val / 2.0)
    rPocPrice


// =============================================================================
// GLOBAL AUTO-OPTIMIZATION STATE VARIABLES
// =============================================================================
var string best_ma_type = "SMA"
var int best_ma_length = 10
var string best_sl_type = "Signal MA"
var float best_rr = 2.0
var float best_metric_val = 0.0
var int best_t_idx = 0
var int best_l_idx = 0
var int best_s_idx = 0
var float best_r_val = 2.0
var int max_lookback = 1000

var float opt_active_sl = na
var float opt_active_tp = na
var bool opt_active = false

// =============================================================================
// WICKLESS MA CALCULATIONS & PLOTTING
// =============================================================================
optSignalMA = getMA(best_ma_type, best_ma_length)

signalMA = getMA(maTypeSignal, maLengthSignal)
slowMA = ta.vwap

body_size = math.abs(close - open)
topWick = high - math.max(open, close)
bottomWick = math.min(open, close) - low
totalWick = topWick + bottomWick
currentRatio = body_size / (totalWick == 0 ? syminfo.mintick : totalWick)
avgBodyToWick = ta.sma(currentRatio, avgLookback)

[isWicklessBullishCTF, isWicklessBearishCTF] = is_candle_wickless(open, high, low, close, avgBodyToWick)

[htfOpen, htfHigh, htfLow, htfClose, htfAvgRatio] = request.security(syminfo.tickerid, htfRes, [open, high, low, close, avgBodyToWick])
[isWicklessBullishHTF, isWicklessBearishHTF] = is_candle_wickless(htfOpen, htfHigh, htfLow, htfClose, htfAvgRatio)

isWicklessBullish = tfMode == "Current Timeframe" ? isWicklessBullishCTF : isWicklessBullishHTF
isWicklessBearish = tfMode == "Current Timeframe" ? isWicklessBearishCTF : isWicklessBearishHTF

signalMAUp = signalMA > signalMA[1]
signalMADown = signalMA < signalMA[1]

buySignal = (signalMA > slowMA) and isWicklessBullish and signalMAUp and (close > signalMA)
sellSignal = (signalMA < slowMA) and isWicklessBearish and signalMADown and (close < signalMA)

// Plot MA and VWAP lines (show optimized MA when autoOptimize is enabled)
plot(autoOptimize ? optSignalMA : signalMA, color=color.new(color.blue, 0), title="Signal MA", linewidth=2)
plot(slowMA, color=color.new(color.red, 0), title="Anchored VWAP (Slow MA)", linewidth=2)

bgcolor(not autoOptimize and isWicklessBullish ? color.new(color.green, 90) : na, title="Wickless Bullish Background")
bgcolor(not autoOptimize and isWicklessBearish ? color.new(color.red, 90) : na, title="Wickless Bearish Background")

plotshape(not autoOptimize and buySignal[1], title="Buy Signal", location=location.belowbar, color=color.new(color.green, 0), style=shape.triangleup, size=size.small, text="BUY")
plotshape(not autoOptimize and sellSignal[1], title="Sell Signal", location=location.abovebar, color=color.new(color.red, 0), style=shape.triangledown, size=size.small, text="SELL")

// Pre-calculate candidate values on every bar
ma_s10 = ta.sma(close, 10)
ma_s20 = ta.sma(close, 20)
ma_s30 = ta.sma(close, 30)
ma_s50 = ta.sma(close, 50)
ma_e10 = ta.ema(close, 10)
ma_e20 = ta.ema(close, 20)
ma_e30 = ta.ema(close, 30)
ma_e50 = ta.ema(close, 50)
ma_h10 = ta.hma(close, 10)
ma_h20 = ta.hma(close, 20)
ma_h30 = ta.hma(close, 30)
ma_h50 = ta.hma(close, 50)

atr14_val = ta.atr(14)
low5_val = ta.lowest(low, 5)
low10_val = ta.lowest(low, 10)
low15_val = ta.lowest(low, 15)
high5_val = ta.highest(high, 5)
high10_val = ta.highest(high, 10)
high15_val = ta.highest(high, 15)


// =============================================================================
// STRATEGY EXECUTION & DYNAMIC SL/TP
// =============================================================================

rollingPoc = showRollPOC ? f_rolling_poc(rollPocLen, rowsInput) : na
var float rollingPocMA = na

if showRollPOC and showRollMA
    if maType == "EMA"
        rollingPocMA := ta.ema(rollingPoc, maLength)
    else if maType == "WMA"
        rollingPocMA := ta.wma(rollingPoc, maLength)
    else
        rollingPocMA := ta.sma(rollingPoc, maLength)

plot(rollingPoc, "Rolling POC", color=rollPocCol, linewidth=1, style=plot.style_line)
plot(rollingPocMA, "Rolling POC MA", color=rollMaCol, linewidth=2)

customMAVal = getMA(slMaType, slMaLen)
atrVal = ta.atr(atrLen)
lookbackLow = ta.lowest(low, lbLen)
lookbackHigh = ta.highest(high, lbLen)

var bool sim_active = false
var int sim_dir = 0
var float sim_sl = na
var float sim_tp = na
var float sim_entry = na
var int sim_entry_bar = na
var float[] trade_profits = array.new_float()

float globalMinRiskDist = math.max(open * 0.001, math.max(syminfo.mintick * 10, atrVal[1] * minSLDist))

// Entry conditions checking (only when flat, executes at the OPEN of the next bar)
if not sim_active and buySignal[1]
    float calculatedSL = na
    if slType == "Signal MA"
        calculatedSL := signalMA[1]
    else if slType == "Custom MA"
        calculatedSL := customMAVal[1]
    else if slType == "ATR"
        calculatedSL := open - (atrVal[1] * atrMult)
    else if slType == "Candle Lookback"
        calculatedSL := lookbackLow[1] * (1 - (lbMargin / 100))
    else if slType == "Volume Profile LVN"
        calculatedSL := f_rolling_lvn(rollPocLen, rowsInput, open, true)
    else if slType == "Moving POC"
        calculatedSL := rollingPoc[1]
        
    if na(calculatedSL)
        calculatedSL := open - atrVal[1]
        
    calculatedSL := math.min(calculatedSL, open - globalMinRiskDist)
    
    sim_active := true
    sim_dir := 1
    sim_entry := open
    sim_entry_bar := bar_index
    sim_sl := calculatedSL
    float risk = open - calculatedSL
    sim_tp := open + (risk * targetRR)

if not sim_active and sellSignal[1]
    float calculatedSL = na
    if slType == "Signal MA"
        calculatedSL := signalMA[1]
    else if slType == "Custom MA"
        calculatedSL := customMAVal[1]
    else if slType == "ATR"
        calculatedSL := open + (atrVal[1] * atrMult)
    else if slType == "Candle Lookback"
        calculatedSL := lookbackHigh[1] * (1 + (lbMargin / 100))
    else if slType == "Volume Profile LVN"
        calculatedSL := f_rolling_lvn(rollPocLen, rowsInput, open, false)
    else if slType == "Moving POC"
        calculatedSL := rollingPoc[1]
        
    if na(calculatedSL)
        calculatedSL := open + atrVal[1]
        
    calculatedSL := math.max(calculatedSL, open + globalMinRiskDist)
        
    sim_active := true
    sim_dir := -1
    sim_entry := open
    sim_entry_bar := bar_index
    sim_sl := calculatedSL
    float risk = calculatedSL - open
    sim_tp := open - (risk * targetRR)

// Exit checking (checked on every bar when active, starting from the bar after entry)
if sim_active and bar_index > sim_entry_bar
    bool closed = false
    float pnl = 0.0
    
    if sim_dir == 1
        if low <= sim_sl
            closed := true
            pnl := -fixedRisk
        else if high >= sim_tp
            closed := true
            pnl := fixedRisk * targetRR
    else if sim_dir == -1
        if high >= sim_sl
            closed := true
            pnl := -fixedRisk
        else if low <= sim_tp
            closed := true
            pnl := fixedRisk * targetRR
            
    if closed
        array.push(trade_profits, pnl)
        sim_active := false
        sim_dir := 0
        sim_entry := na
        sim_entry_bar := na
        sim_sl := na
        sim_tp := na

bool show_lines = not autoOptimize and sim_active
plot(autoOptimize ? (opt_active ? opt_active_sl : na) : (show_lines ? sim_sl : na), title="Stop Loss", style=plot.style_linebr, color=color.new(color.red, 0), linewidth=2)
plot(autoOptimize ? (opt_active ? opt_active_tp : na) : (show_lines ? sim_tp : na), title="Take Profit", style=plot.style_linebr, color=color.new(color.green, 0), linewidth=2)

// =============================================================================
// AUTO OPTIMIZATION ENGINE (Runs on last bar only)
// =============================================================================
var line[] optLines = array.new_line()
var label[] optLabels = array.new_label()
var box[] optBoxes = array.new_box()

bool run_sweep = (barstate.islastconfirmedhistory or (barstate.islast and barstate.isconfirmed)) and autoOptimize
bool run_drawings = (barstate.islastconfirmedhistory or barstate.islast) and autoOptimize

if run_drawings
    // Clear normal trade profits
    array.clear(trade_profits)
    
    // Clear previous drawings
    if array.size(optLines) > 0
        for l in optLines
            line.delete(l)
        array.clear(optLines)
    if array.size(optLabels) > 0
        for lb in optLabels
            label.delete(lb)
        array.clear(optLabels)
    if array.size(optBoxes) > 0
        for b in optBoxes
            box.delete(b)
        array.clear(optBoxes)
        
    if run_sweep
        float max_metric = -99999999.0
        best_t_idx := 0
        best_l_idx := 0
        best_s_idx := 0
        best_r_val := 2.0

        int rrSteps = math.floor((optMaxRR - optMinRR) / optRRStep) + 1

        // Safe lookback window
        max_lookback := math.min(bar_index, optLookback)
        if optMethod == "Brute Force (Slow)" and max_lookback > 1000
            max_lookback := 1000

        if optMethod == "Two-Stage (Fast)"
            // --- STAGE 1: Optimize Entry MA Settings ---
            // Establish baseline exits based on current inputs
            int base_s_idx = slType == "Signal MA" ? 0 :
                             slType == "ATR" ? (atrMult <= 1.0 ? 1 : atrMult <= 1.5 ? 2 : 3) :
                             slType == "Candle Lookback" ? (lbLen <= 5 ? 4 : lbLen <= 10 ? 5 : 6) : 2
            float base_rr = targetRR

            float stage1_max_metric = -99999999.0

            for ma_type_idx = 0 to 2 // 0=SMA, 1=EMA, 2=HMA
                for ma_len_idx = 0 to 3 // 0=10, 1=20, 2=30, 3=50
                    bool o_sim_active = false
                    int o_sim_dir = 0
                    float o_sim_sl = na
                    float o_sim_tp = na

                    int total_trades = 0
                    int wins = 0
                    float net_pnl = 0.0
                    float gross_wins = 0.0
                    float gross_losses = 0.0

                    // Chronological simulation over the lookback window using series history referencing
                    for loop_idx = 1 to max_lookback - 1
                        int ago = max_lookback - loop_idx
                        float c_val = close[ago]
                        float o_val = open[ago]
                        float h_val = high[ago]
                        float l_val = low[ago]

                        float ma_val = na
                        float ma_prev = na

                        if ma_type_idx == 0
                            if ma_len_idx == 0
                                ma_val := ma_s10[ago]
                                ma_prev := ma_s10[ago + 1]
                            else if ma_len_idx == 1
                                ma_val := ma_s20[ago]
                                ma_prev := ma_s20[ago + 1]
                            else if ma_len_idx == 2
                                ma_val := ma_s30[ago]
                                ma_prev := ma_s30[ago + 1]
                            else
                                ma_val := ma_s50[ago]
                                ma_prev := ma_s50[ago + 1]
                        else if ma_type_idx == 1
                            if ma_len_idx == 0
                                ma_val := ma_e10[ago]
                                ma_prev := ma_e10[ago + 1]
                            else if ma_len_idx == 1
                                ma_val := ma_e20[ago]
                                ma_prev := ma_e20[ago + 1]
                            else if ma_len_idx == 2
                                ma_val := ma_e30[ago]
                                ma_prev := ma_e30[ago + 1]
                            else
                                ma_val := ma_e50[ago]
                                ma_prev := ma_e50[ago + 1]
                        else
                            if ma_len_idx == 0
                                ma_val := ma_h10[ago]
                                ma_prev := ma_h10[ago + 1]
                            else if ma_len_idx == 1
                                ma_val := ma_h20[ago]
                                ma_prev := ma_h20[ago + 1]
                            else if ma_len_idx == 2
                                ma_val := ma_h30[ago]
                                ma_prev := ma_h30[ago + 1]
                            else
                                ma_val := ma_h50[ago]
                                ma_prev := ma_h50[ago + 1]

                        float vwap_val = slowMA[ago]
                        bool is_bull = isWicklessBullish[ago]
                        bool is_bear = isWicklessBearish[ago]

                        bool sig_buy = (ma_val > vwap_val) and is_bull and (ma_val > ma_prev) and (c_val > ma_val)
                        bool sig_sell = (ma_val < vwap_val) and is_bear and (ma_val < ma_prev) and (c_val < ma_val)

                        if not o_sim_active and ago > 1
                            float o_val_next = open[ago - 1]
                            if sig_buy
                                float sl = na
                                if base_s_idx == 0
                                    sl := ma_val
                                else if base_s_idx == 1
                                    sl := o_val_next - atr14_val[ago] * 1.0
                                else if base_s_idx == 2
                                    sl := o_val_next - atr14_val[ago] * 1.5
                                else if base_s_idx == 3
                                    sl := o_val_next - atr14_val[ago] * 2.0
                                else if base_s_idx == 4
                                    sl := low5_val[ago] * (1 - (lbMargin / 100))
                                else if base_s_idx == 5
                                    sl := low10_val[ago] * (1 - (lbMargin / 100))
                                else if base_s_idx == 6
                                    sl := low15_val[ago] * (1 - (lbMargin / 100))

