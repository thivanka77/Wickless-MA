                line sl_ln = line.new(x1=actual_entry_bar, y1=f_sl, x2=actual_exit_bar, y2=f_sl,
                             color=color.new(color.red, 40), style=line.style_solid, width=2)
                array.push(optLines, sl_ln)
                
                // Draw horizontal TP line (green)
                line tp_ln = line.new(x1=actual_entry_bar, y1=f_tp, x2=actual_exit_bar, y2=f_tp,
                             color=color.new(color.green, 40), style=line.style_solid, width=2)
                array.push(optLines, tp_ln)
                
                // Draw horizontal dotted Entry line (blue, thickness=2)
                line entry_ln = line.new(x1=actual_entry_bar, y1=f_entry_price, x2=actual_exit_bar, y2=f_entry_price,
                               color=color.new(color.blue, 30), style=line.style_dotted, width=2)
                array.push(optLines, entry_ln)
                
                // Shade Entry-to-TP in green
                box tp_bx = box.new(left=actual_entry_bar, top=math.max(f_entry_price, f_tp), right=actual_exit_bar, bottom=math.min(f_entry_price, f_tp), bgcolor=color.new(color.green, 92), border_color=color.new(color.white, 100))
                array.push(optBoxes, tp_bx)
                
                // Shade Entry-to-SL in red
                box sl_bx = box.new(left=actual_entry_bar, top=math.max(f_entry_price, f_sl), right=actual_exit_bar, bottom=math.min(f_entry_price, f_sl), bgcolor=color.new(color.red, 92), border_color=color.new(color.white, 100))
                array.push(optBoxes, sl_bx)
                
                f_active := false
                f_dir := 0
                f_sl := na
                f_tp := na
                f_entry_price := na

    // Store active trade info for plotting on the current bar
    opt_active := f_active
    opt_active_sl := f_sl
    opt_active_tp := f_tp
    
    // Draw active optimized signal TP/SL lines dynamically on chart
    if f_active
        int actual_entry_bar = bar_index - f_entry_ago
        color active_col = f_dir == 1 ? color.green : color.red
        
        string active_entry_text = f_dir == 1 ? "Buy" : "Sell"
        label el = label.new(x=actual_entry_bar, y=na, text=active_entry_text,
                   style=f_dir == 1 ? label.style_triangleup : label.style_triangledown,
                   color=active_col, textcolor=color.white,
                   yloc=f_dir == 1 ? yloc.belowbar : yloc.abovebar, size=size.small)
        array.push(optLabels, el)
        
        // Active SL line (red) extending to current bar
        line active_sl_ln = line.new(x1=actual_entry_bar, y1=f_sl, x2=bar_index, y2=f_sl,
                             color=color.new(color.red, 20), style=line.style_solid, width=2)
        array.push(optLines, active_sl_ln)
        
        // Active TP line (green) extending to current bar
        line active_tp_ln = line.new(x1=actual_entry_bar, y1=f_tp, x2=bar_index, y2=f_tp,
                             color=color.new(color.green, 20), style=line.style_solid, width=2)
        array.push(optLines, active_tp_ln)
        
        // Active horizontal dotted Entry line (blue, thickness=2) extending to current bar
        line active_entry_ln = line.new(x1=actual_entry_bar, y1=f_entry_price, x2=bar_index, y2=f_entry_price,
                               color=color.new(color.blue, 30), style=line.style_dotted, width=2)
        array.push(optLines, active_entry_ln)
        
        // Active Shade Entry-to-TP in green
        box active_tp_bx = box.new(left=actual_entry_bar, top=math.max(f_entry_price, f_tp), right=bar_index, bottom=math.min(f_entry_price, f_tp), bgcolor=color.new(color.green, 92), border_color=color.new(color.white, 100))
        array.push(optBoxes, active_tp_bx)
        
        // Active Shade Entry-to-SL in red
        box active_sl_bx = box.new(left=actual_entry_bar, top=math.max(f_entry_price, f_sl), right=bar_index, bottom=math.min(f_entry_price, f_sl), bgcolor=color.new(color.red, 92), border_color=color.new(color.white, 100))
        array.push(optBoxes, active_sl_bx)

// =============================================================================
// VOLUME PROFILE CALCULATIONS & DRAWINGS
// =============================================================================

var box[] profileBoxes = array.new_box()
var line fixedPocLine = na

if barstate.islastconfirmedhistory or barstate.islast
    int startBarIndex = na
    if periodType == "Fixed Range"
        startBarIndex := math.max(0, bar_index - lookback + 1)
    else
        for i = 0 to math.min(bar_index, 5000)
            if time[i] < chart.left_visible_bar_time
                startBarIndex := bar_index - i + 1
                break
        if na(startBarIndex)
            startBarIndex := 0

    float hi = high
    float lo = low
    int totalBars = bar_index - startBarIndex + 1
    for i = 1 to totalBars - 1
        hi := math.max(hi, high[i])
        lo := math.min(lo, low[i])
        
    float step_val = hi == lo ? 0.0001 : (hi - lo) / rowsInput

    float[] binVolumes = array.new_float(rowsInput, 0.0)
    float[] binUpVolumes = array.new_float(rowsInput, 0.0)
    float[] binDownVolumes = array.new_float(rowsInput, 0.0)

    for i = 0 to totalBars - 1
        // Fallback to 1.0 if volume is 0 so it doesn't break on Forex/CFDs
        float barVol = nz(volume[i]) == 0 ? 1.0 : nz(volume[i])
        
        float barHigh = high[i]
        float barLow = low[i]
        float barClose = close[i]
        float barOpen = open[i]
        bool isUp = barClose >= barOpen
        
        if barHigh == barLow
            int binIdx = math.min(rowsInput - 1, math.max(0, math.floor((barClose - lo) / step_val)))
            array.set(binVolumes, binIdx, array.get(binVolumes, binIdx) + barVol)
            if isUp
                array.set(binUpVolumes, binIdx, array.get(binUpVolumes, binIdx) + barVol)
            else
                array.set(binDownVolumes, binIdx, array.get(binDownVolumes, binIdx) + barVol)
        else
            for j = 0 to rowsInput - 1
                float binMin = lo + j * step_val
                float binMax = binMin + step_val
                float overlapMin = math.max(barLow, binMin)
                float overlapMax = math.min(barHigh, binMax)
                
                if overlapMax > overlapMin
                    float proportion = (overlapMax - overlapMin) / (barHigh - barLow)
                    float allocatedVol = barVol * proportion
                    array.set(binVolumes, j, array.get(binVolumes, j) + allocatedVol)
                    if isUp
                        array.set(binUpVolumes, j, array.get(binUpVolumes, j) + allocatedVol)
                    else
                        array.set(binDownVolumes, j, array.get(binDownVolumes, j) + allocatedVol)

    float maxVol = 0.0
    int pocBinIdx = 0
    for j = 0 to rowsInput - 1
        float v = array.get(binVolumes, j)
        if v > maxVol
            maxVol := v
            pocBinIdx := j

    if maxVol == 0
        maxVol := 1.0 // Prevent division by zero runtime error

    float pocPrice = lo + pocBinIdx * step_val + (step_val / 2.0)
    float hvnThresholdVal = maxVol * (hvnThresh / 100.0)

    if array.size(profileBoxes) > 0
        for b in profileBoxes
            box.delete(b)
        array.clear(profileBoxes)

    int baseRight = bar_index + offsetInput
    for j = 0 to rowsInput - 1
        float v = array.get(binVolumes, j)
        if v == 0
            continue
            
        float upVol = array.get(binUpVolumes, j)
        float downVol = array.get(binDownVolumes, j)
        
        int totalWidth = math.round(widthInput * (v / maxVol))
        int upWidth = math.round(widthInput * (upVol / maxVol))
        
        float binBottom = lo + j * step_val
        float binTop = binBottom + step_val
        
        bool isHVN = v >= hvnThresholdVal
        
        color currentUpColor = isHVN ? hvnUpColor : upColor
        color currentDownColor = isHVN ? hvnDownColor : downColor
        
        int downLeft = baseRight - totalWidth
        box downBox = box.new(
             left=downLeft, top=binTop,
             right=baseRight, bottom=binBottom,
             bgcolor=currentDownColor, border_color=color.new(color.white, 100),
             border_style=line.style_solid
             )
        array.push(profileBoxes, downBox)
        
        if upWidth > 0
            int upLeft = baseRight - upWidth
            box upBox = box.new(
                 left=upLeft, top=binTop,
                 right=baseRight, bottom=binBottom,
                 bgcolor=currentUpColor, border_color=color.new(color.white, 100),
                 border_style=line.style_solid
                 )
            array.push(profileBoxes, upBox)

    if showFixedPOC
        if not na(fixedPocLine)
            line.delete(fixedPocLine)
        fixedPocLine := line.new(
             x1=startBarIndex, y1=pocPrice,
             x2=baseRight, y2=pocPrice,
             color=fixedPocCol, width=2, style=line.style_solid
             )

// =============================================================================
// RESULTS DASHBOARD
// =============================================================================
var float first_bar_time = na
if bar_index == 0
    first_bar_time := time

var table resTable = na
if (barstate.islastconfirmedhistory or barstate.islast) and showDash
    tablePos = dashLoc == "top_right" ? position.top_right :
               dashLoc == "top_left" ? position.top_left :
               dashLoc == "bottom_right" ? position.bottom_right :
               position.bottom_left
               
    if na(resTable)
        resTable := table.new(position=tablePos, columns=2, rows=14, bgcolor=color.new(#16163a, 0), border_color=color.new(#2a2a4a, 0), border_width=1)
    
    int totTrades = array.size(trade_profits)
    int wins = 0
    float netProfit = 0.0
    float grossWins = 0.0
    float grossLosses = 0.0
    float maxGain = 0.0
    float maxLoss = 0.0
    
    float maxDD = 0.0
    float peak = 0.0
    float current_equity = 0.0
    
    if totTrades > 0
        for i = 0 to totTrades - 1
            float p = array.get(trade_profits, i)
            netProfit += p
            current_equity += p
            
            if p > 0
                wins += 1
                grossWins += p
            else
                grossLosses += math.abs(p)
                
            if p > maxGain
                maxGain := p
            if p < maxLoss
                maxLoss := p
                
            if current_equity > peak
                peak := current_equity
            float dd = peak - current_equity
            if dd > maxDD
                maxDD := dd
                
    float winRate = totTrades > 0 ? (wins / totTrades) * 100 : 0
    float pf = grossLosses == 0 ? (grossWins > 0 ? 999.9 : 0.0) : grossWins / grossLosses
    float expect = totTrades > 0 ? netProfit / totTrades : 0
    
    int timeOffset = autoOptimize ? math.min(bar_index, optLookback) - 1 : bar_index
    float elapsedDays = (time - nz(time[timeOffset], time[1])) / 86400000
    if elapsedDays == 0
        elapsedDays := 1
        
    float tradesPerDay = totTrades / elapsedDays
    float avgMonthly = (netProfit / elapsedDays) * 30.44
    
    float maxDD_val = maxDD
    
    color bgTitle = color.new(#12122a, 0)
    color bgCell = color.new(#16163a, 0)
    color textKey = color.new(#aaaacc, 0)
    color colGreen = color.new(#00c853, 0)
    color colRed = color.new(#ff1744, 0)
    
    string tSize = dashSize == "Tiny" ? size.tiny : dashSize == "Small" ? size.small : dashSize == "Normal" ? size.normal : dashSize == "Large" ? size.large : size.auto
    
    table.cell(resTable, 0, 0, autoOptimize ? "📊 Optimized Results 📊" : "📊 Strategy Results 📊", text_color=color.white, text_size=tSize, bgcolor=bgTitle)
    table.merge_cells(resTable, 0, 0, 1, 0)
    
    color wrCol = winRate >= 50 ? colGreen : colRed
    table.cell(resTable, 0, 1, "Win Rate", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 1, str.tostring(winRate, "#.##") + "% (" + str.tostring(wins) + "/" + str.tostring(totTrades) + ")", text_color=wrCol, text_size=tSize, bgcolor=bgCell)

    color npCol = netProfit >= 0 ? colGreen : colRed
    string npPrefix = netProfit >= 0 ? "+$" : "-$"
    table.cell(resTable, 0, 2, "Net Profit", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 2, npPrefix + str.tostring(math.abs(netProfit), "#.##"), text_color=npCol, text_size=tSize, bgcolor=bgCell)

    color pfCol = pf >= 1.5 ? colGreen : (pf >= 1.0 ? color.white : colRed)
    string pfText = pf >= 999.0 ? "∞" : str.tostring(pf, "#.##")
    table.cell(resTable, 0, 3, "Profit Factor", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 3, pfText, text_color=pfCol, text_size=tSize, bgcolor=bgCell)

    color expCol = expect >= 0 ? colGreen : colRed
    string expPrefix = expect >= 0 ? "+$" : "-$"
    table.cell(resTable, 0, 4, "Expectancy", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 4, expPrefix + str.tostring(math.abs(expect), "#.##"), text_color=expCol, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 5, "Trades / Day", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 5, str.tostring(tradesPerDay, "#.##"), text_color=color.white, text_size=tSize, bgcolor=bgCell)

    color avgCol = avgMonthly >= 0 ? colGreen : colRed
    string avgPrefix = avgMonthly >= 0 ? "+$" : "-$"
    table.cell(resTable, 0, 6, "Avg Monthly", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 6, avgPrefix + str.tostring(math.abs(avgMonthly), "#.##"), text_color=avgCol, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 7, "Target R:R", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 7, "1 : " + str.tostring(autoOptimize ? best_rr : targetRR, "#.#"), text_color=color.white, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 8, "Max Gain", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 8, "+$" + str.tostring(maxGain, "#.##"), text_color=colGreen, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 9, "Max Loss", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 9, "-$" + str.tostring(math.abs(maxLoss), "#.##"), text_color=colRed, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 10, "Max Drawdown", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 10, "-$" + str.tostring(math.abs(maxDD), "#.##"), text_color=colRed, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 11, "Opt. Signal MA", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 11, autoOptimize ? best_ma_type + " " + str.tostring(best_ma_length) : "Disabled", text_color=autoOptimize ? colGreen : color.white, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 12, "Opt. Stop Loss", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 12, autoOptimize ? best_sl_type : "Disabled", text_color=autoOptimize ? colGreen : color.white, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 13, "Opt. Target RR", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 13, autoOptimize ? "1 : " + str.tostring(best_rr, "#.#") : "Disabled", text_color=autoOptimize ? colGreen : color.white, text_size=tSize, bgcolor=bgCell)
