//@version=5
indicator("Wickless MA Strategy + Volume Profile", overlay=true, max_boxes_count=500, max_lines_count=500, max_bars_back=5000)

// =============================================================================
// WICKLESS MA INPUTS
// =============================================================================
grpMA = "Signal MA Settings"
maTypeSignal = input.string("SMA", "Signal MA Type", options=["SMA", "EMA", "WMA", "VWAP", "Anchored VWAP", "HMA"], group=grpMA)
maLengthSignal = input.int(10, "Signal MA Length", minval=1, group=grpMA)

grpWick = "Wickless Candle Settings"
strictnessMult = input.float(2.0, "Wickless Ratio Strictness", minval=0.1, step=0.5, tooltip="How much higher the Body-to-Wick ratio must be compared to the average.", group=grpWick)
avgLookback = input.int(10, "Average Lookback Length", minval=1, group=grpWick)

grpTF = "Timeframe Settings"
tfMode = input.string("Current Timeframe", "Wickless Detection Mode", options=["Current Timeframe", "Higher Timeframe"], group=grpTF)
htfRes = input.timeframe("60", "Higher Timeframe", group=grpTF)

// =============================================================================
// VOLUME PROFILE INPUTS
// =============================================================================
gp_profile  = "Volume Profile Settings"
periodType  = input.string("Fixed Range", "Period Type", options=["Fixed Range", "Visible Range"], group=gp_profile)
lookback    = input.int(200, "Fixed Range Lookback (bars)", minval=10, maxval=5000, group=gp_profile, tooltip="Only active if Period Type is 'Fixed Range'")
rowsInput   = input.int(50, "Number of Rows (Bins)", minval=5, maxval=100, group=gp_profile)
widthInput  = input.int(30, "Profile Width (bars)", minval=5, maxval=200, group=gp_profile)
offsetInput = input.int(0, "Horizontal Offset (bars)", minval=0, group=gp_profile)
hvnThresh   = input.float(70.0, "HVN Threshold (%)", minval=1.0, maxval=100.0, group=gp_profile, tooltip="Volume nodes exceeding this percentage of Max Volume are marked as High Value Nodes")

gp_colors   = "Color Settings"
upColor     = input.color(color.new(#26a69a, 60), "Up Volume Color", group=gp_colors)
downColor   = input.color(color.new(#ef5350, 60), "Down Volume Color", group=gp_colors)
hvnUpColor  = input.color(color.new(#ffca28, 40), "HVN Up Color", group=gp_colors)
hvnDownColor= input.color(color.new(#ff8f00, 40), "HVN Down Color", group=gp_colors)

gp_poc      = "Point of Control (POC)"
showFixedPOC = input.bool(true, "Show Fixed POC Line", group=gp_poc)
fixedPocCol = input.color(color.red, "Fixed POC Color", group=gp_poc)
showRollPOC  = input.bool(true, "Show Rolling POC", group=gp_poc)
rollPocCol   = input.color(color.blue, "Rolling POC Color", group=gp_poc)
rollPocLen   = input.int(50, "Rolling POC Length (bars)", minval=5, maxval=500, group=gp_poc)
showRollMA   = input.bool(true, "Show Rolling POC MA Line", group=gp_poc)
maLength     = input.int(20, "Rolling POC MA Length", minval=2, group=gp_poc)
maType       = input.string("EMA", "Rolling POC MA Type", options=["SMA", "EMA", "WMA"], group=gp_poc)
rollMaCol    = input.color(color.orange, "Rolling POC MA Color", group=gp_poc)

gp_dash      = "Dashboard Settings"
showDash     = input.bool(true, "Show Results Dashboard", group=gp_dash)
dashLoc      = input.string("top_right", "Dashboard Position", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=gp_dash)
dashSize     = input.string("Small", "Dashboard Size", options=["Tiny", "Small", "Normal", "Large", "Auto"], group=gp_dash)

gp_risk      = "Risk Management"
fixedRisk    = input.float(100.0, "Fixed $ Risk per Trade", minval=1.0, group=gp_risk)
minSLDist    = input.float(1.0, "Minimum SL Distance (ATR Mult)", minval=0.1, step=0.1, group=gp_risk, tooltip="Prevents stop loss from being placed too close to entry.")

gp_sltp      = "Stop Loss & Take Profit"
slType       = input.string("Signal MA", "Stop Loss Mode", options=["Signal MA", "Custom MA", "ATR", "Candle Lookback", "Volume Profile LVN", "Moving POC"], group=gp_sltp)
targetRR     = input.float(2.0, "Target Risk:Reward Ratio", minval=0.1, step=0.1, group=gp_sltp)

slMaType     = input.string("SMA", "Custom MA Type", options=["SMA", "EMA", "HMA"], group=gp_sltp, tooltip="Only for Custom MA Stop Loss")
slMaLen      = input.int(50, "Custom MA Length", minval=1, group=gp_sltp)

atrLen       = input.int(14, "ATR Length", minval=1, group=gp_sltp)
atrMult      = input.float(1.5, "ATR Multiplier", minval=0.1, step=0.1, group=gp_sltp)

lbLen        = input.int(10, "Candle Lookback Length", minval=1, group=gp_sltp)
lbMargin     = input.float(0.5, "Candle Margin (%)", minval=0.0, step=0.1, group=gp_sltp, tooltip="Margin percentage of price to add/subtract from the lowest low / highest high")

// =============================================================================
// HELPER FUNCTIONS
// =============================================================================
getMA(type, length) =>
    float ma = na
    if type == "SMA"
        ma := ta.sma(close, length)
    else if type == "EMA"
        ma := ta.ema(close, length)
    else if type == "WMA"
        ma := ta.wma(close, length)
    else if type == "VWAP"
        ma := nz(volume) == 0 ? ta.sma(hlc3, length) : ta.vwma(hlc3, length)
    else if type == "Anchored VWAP"
        ma := ta.vwap
    else if type == "HMA"
        ma := ta.hma(close, length)
    ma

is_candle_wickless(o, h, l, c, avgRatio) =>
    body_val = math.abs(c - o)
    topWick = h - math.max(o, c)
    bottomWick = math.min(o, c) - l
    totalWick = topWick + bottomWick
    
    ratio = body_val / (totalWick == 0 ? syminfo.mintick : totalWick)
    isWickless = ratio > (avgRatio * strictnessMult)
    
    bullishWickless = isWickless and (c > o)
    bearishWickless = isWickless and (c < o)
    
    [bullishWickless, bearishWickless]

// VOLUME PROFILE: Calculate rolling LVN
f_rolling_lvn(int len, int rows, float currentPrice, bool isLong) =>
    float hi = ta.highest(high, len)
    float lo = ta.lowest(low, len)
    float rLvnPrice = na
    
    if not na(hi) and not na(lo)
        float step_val = hi == lo ? 0.0001 : (hi - lo) / rows
        float[] rVolumes = array.new_float(rows, 0.0)
        
        for i = 0 to len - 1
            float barVol = nz(volume[i]) == 0 ? 1.0 : nz(volume[i])
            float barHigh = high[i]
            float barLow = low[i]
            float barClose = close[i]
            
            if barHigh == barLow
                int binIdx = math.min(rows - 1, math.max(0, math.floor((barClose - lo) / step_val)))
                array.set(rVolumes, binIdx, array.get(rVolumes, binIdx) + barVol)
            else
                for j = 0 to rows - 1
                    float binMin = lo + j * step_val
                    float binMax = binMin + step_val
                    float overlapMin = math.max(barLow, binMin)
                    float overlapMax = math.min(barHigh, binMax)
                    if overlapMax > overlapMin
                        float proportion = (overlapMax - overlapMin) / (barHigh - barLow)
                        array.set(rVolumes, j, array.get(rVolumes, j) + barVol * proportion)
                        
        float totalVol = 0.0
        for j = 0 to rows - 1
            totalVol += array.get(rVolumes, j)
        float avgVol = totalVol / rows
        
        float closestLvnPrice = na
        float minDistance = 9999999.9
        
        for j = 0 to rows - 1
            float v = array.get(rVolumes, j)
            float binPrice = lo + j * step_val + (step_val / 2.0)
            
            if v < avgVol * 0.75 // significantly lower than average
                if isLong and binPrice < currentPrice
                    float dist = currentPrice - binPrice
                    if dist < minDistance
                        minDistance := dist
                        closestLvnPrice := binPrice
                else if not isLong and binPrice > currentPrice
                    float dist = binPrice - currentPrice
                    if dist < minDistance
                        minDistance := dist
                        closestLvnPrice := binPrice
                        
        rLvnPrice := closestLvnPrice
    rLvnPrice

// VOLUME PROFILE: Calculate rolling POC
f_rolling_poc(int len, int rows) =>
    float hi = ta.highest(high, len)
    float lo = ta.lowest(low, len)
    float rPocPrice = na
    
    if not na(hi) and not na(lo)
        float step_val = hi == lo ? 0.0001 : (hi - lo) / rows
        float[] rVolumes = array.new_float(rows, 0.0)
        
        for i = 0 to len - 1
            float barVol = nz(volume[i]) == 0 ? 1.0 : nz(volume[i])
            float barHigh = high[i]
            float barLow = low[i]
            float barClose = close[i]
            
            if barHigh == barLow
                int binIdx = math.min(rows - 1, math.max(0, math.floor((barClose - lo) / step_val)))
                array.set(rVolumes, binIdx, array.get(rVolumes, binIdx) + barVol)
            else
                for j = 0 to rows - 1
                    float binMin = lo + j * step_val
                    float binMax = binMin + step_val
                    float overlapMin = math.max(barLow, binMin)
                    float overlapMax = math.min(barHigh, binMax)
                    if overlapMax > overlapMin
                        float proportion = (overlapMax - overlapMin) / (barHigh - barLow)
                        array.set(rVolumes, j, array.get(rVolumes, j) + barVol * proportion)
                        
        float maxVol = 0.0
        int pocBinIdx = 0
        for j = 0 to rows - 1
            float v = array.get(rVolumes, j)
            if v > maxVol
                maxVol := v
                pocBinIdx := j
                
        rPocPrice := lo + pocBinIdx * step_val + (step_val / 2.0)
    rPocPrice


// =============================================================================
// WICKLESS MA CALCULATIONS & PLOTTING
// =============================================================================
signalMA = getMA(maTypeSignal, maLengthSignal)
slowMA = ta.vwap

body_size = math.abs(close - open)
topWick = high - math.max(open, close)
bottomWick = math.min(open, close) - low
totalWick = topWick + bottomWick
currentRatio = body_size / (totalWick == 0 ? syminfo.mintick : totalWick)
avgBodyToWick = ta.sma(currentRatio, avgLookback)

[isWicklessBullishCTF, isWicklessBearishCTF] = is_candle_wickless(open, high, low, close, avgBodyToWick)

[htfOpen, htfHigh, htfLow, htfClose, htfAvgRatio] = request.security(syminfo.tickerid, htfRes, [open, high, low, close, avgBodyToWick])
[isWicklessBullishHTF, isWicklessBearishHTF] = is_candle_wickless(htfOpen, htfHigh, htfLow, htfClose, htfAvgRatio)

isWicklessBullish = tfMode == "Current Timeframe" ? isWicklessBullishCTF : isWicklessBullishHTF
isWicklessBearish = tfMode == "Current Timeframe" ? isWicklessBearishCTF : isWicklessBearishHTF

signalMAUp = signalMA > signalMA[1]
signalMADown = signalMA < signalMA[1]

buySignal = (signalMA > slowMA) and isWicklessBullish and signalMAUp and (close > signalMA)
sellSignal = (signalMA < slowMA) and isWicklessBearish and signalMADown and (close < signalMA)

plot(signalMA, color=color.new(color.blue, 0), title="Signal MA", linewidth=2)
plot(slowMA, color=color.new(color.red, 0), title="Anchored VWAP (Slow MA)", linewidth=2)

bgcolor(isWicklessBullish ? color.new(color.green, 90) : na, title="Wickless Bullish Background")
bgcolor(isWicklessBearish ? color.new(color.red, 90) : na, title="Wickless Bearish Background")

plotshape(buySignal, title="Buy Signal", location=location.belowbar, color=color.new(color.green, 0), style=shape.triangleup, size=size.small, text="BUY")
plotshape(sellSignal, title="Sell Signal", location=location.abovebar, color=color.new(color.red, 0), style=shape.triangledown, size=size.small, text="SELL")

// =============================================================================
// STRATEGY EXECUTION & DYNAMIC SL/TP
// =============================================================================

rollingPoc = showRollPOC ? f_rolling_poc(rollPocLen, rowsInput) : na
var float rollingPocMA = na

if showRollPOC and showRollMA
    if maType == "EMA"
        rollingPocMA := ta.ema(rollingPoc, maLength)
    else if maType == "WMA"
        rollingPocMA := ta.wma(rollingPoc, maLength)
    else
        rollingPocMA := ta.sma(rollingPoc, maLength)

plot(rollingPoc, "Rolling POC", color=rollPocCol, linewidth=1, style=plot.style_line)
plot(rollingPocMA, "Rolling POC MA", color=rollMaCol, linewidth=2)

customMAVal = getMA(slMaType, slMaLen)
atrVal = ta.atr(atrLen)
lookbackLow = ta.lowest(low, lbLen)
lookbackHigh = ta.highest(high, lbLen)

var bool sim_active = false
var int sim_dir = 0
var float sim_sl = na
var float sim_tp = na
var float sim_entry = na
var int sim_entry_bar = na
var float[] trade_profits = array.new_float()

// Entry conditions checking (only when flat)
if not sim_active and buySignal
    float calculatedSL = na
    if slType == "Signal MA"
        calculatedSL := signalMA
    else if slType == "Custom MA"
        calculatedSL := customMAVal
    else if slType == "ATR"
        calculatedSL := close - (atrVal * atrMult)
    else if slType == "Candle Lookback"
        calculatedSL := lookbackLow * (1 - (lbMargin / 100))
    else if slType == "Volume Profile LVN"
        calculatedSL := f_rolling_lvn(rollPocLen, rowsInput, close, true)
    else if slType == "Moving POC"
        calculatedSL := rollingPoc
        
    if na(calculatedSL)
        calculatedSL := close - atrVal
        
    float minRiskDist = math.max(close * 0.001, math.max(syminfo.mintick * 10, atrVal * minSLDist))
    calculatedSL := math.min(calculatedSL, close - minRiskDist)
    
    sim_active := true
    sim_dir := 1
    sim_entry := close
    sim_entry_bar := bar_index
    sim_sl := calculatedSL
    float risk = close - calculatedSL
    sim_tp := close + (risk * targetRR)

if not sim_active and sellSignal
    float calculatedSL = na
    if slType == "Signal MA"
        calculatedSL := signalMA
    else if slType == "Custom MA"
        calculatedSL := customMAVal
    else if slType == "ATR"
        calculatedSL := close + (atrVal * atrMult)
    else if slType == "Candle Lookback"
        calculatedSL := lookbackHigh * (1 + (lbMargin / 100))
    else if slType == "Volume Profile LVN"
        calculatedSL := f_rolling_lvn(rollPocLen, rowsInput, close, false)
    else if slType == "Moving POC"
        calculatedSL := rollingPoc
        
    if na(calculatedSL)
        calculatedSL := close + atrVal
        
    float minRiskDist = math.max(close * 0.001, math.max(syminfo.mintick * 10, atrVal * minSLDist))
    calculatedSL := math.max(calculatedSL, close + minRiskDist)
        
    sim_active := true
    sim_dir := -1
    sim_entry := close
    sim_entry_bar := bar_index
    sim_sl := calculatedSL
    float risk = calculatedSL - close
    sim_tp := close - (risk * targetRR)

// Exit checking (checked on every bar when active, starting from the bar after entry)
if sim_active and bar_index > sim_entry_bar
    bool closed = false
    float pnl = 0.0
    
    if sim_dir == 1
        if low <= sim_sl
            closed := true
            pnl := -fixedRisk
        else if high >= sim_tp
            closed := true
            pnl := fixedRisk * targetRR
    else if sim_dir == -1
        if high >= sim_sl
            closed := true
            pnl := -fixedRisk
        else if low <= sim_tp
            closed := true
            pnl := fixedRisk * targetRR
            
    if closed
        array.push(trade_profits, pnl)
        sim_active := false
        sim_dir := 0
        sim_entry := na
        sim_entry_bar := na
        sim_sl := na
        sim_tp := na

bool show_lines = sim_active
plot(show_lines ? sim_sl : na, title="Stop Loss", style=plot.style_linebr, color=color.new(color.red, 0), linewidth=2)
plot(show_lines ? sim_tp : na, title="Take Profit", style=plot.style_linebr, color=color.new(color.green, 0), linewidth=2)

// =============================================================================
// VOLUME PROFILE CALCULATIONS & DRAWINGS
// =============================================================================

var box[] profileBoxes = array.new_box()
var line fixedPocLine = na

if barstate.islastconfirmedhistory or barstate.islast
    int startBarIndex = na
    if periodType == "Fixed Range"
        startBarIndex := math.max(0, bar_index - lookback + 1)
    else
        for i = 0 to math.min(bar_index, 5000)
            if time[i] < chart.left_visible_bar_time
                startBarIndex := bar_index - i + 1
                break
        if na(startBarIndex)
            startBarIndex := 0

    float hi = high
    float lo = low
    int totalBars = bar_index - startBarIndex + 1
    for i = 1 to totalBars - 1
        hi := math.max(hi, high[i])
        lo := math.min(lo, low[i])
        
    float step_val = hi == lo ? 0.0001 : (hi - lo) / rowsInput

    float[] binVolumes = array.new_float(rowsInput, 0.0)
    float[] binUpVolumes = array.new_float(rowsInput, 0.0)
    float[] binDownVolumes = array.new_float(rowsInput, 0.0)

    for i = 0 to totalBars - 1
        float barVol = nz(volume[i]) == 0 ? 1.0 : nz(volume[i])
        
        float barHigh = high[i]
        float barLow = low[i]
        float barClose = close[i]
        float barOpen = open[i]
        bool isUp = barClose >= barOpen
        
        if barHigh == barLow
            int binIdx = math.min(rowsInput - 1, math.max(0, math.floor((barClose - lo) / step_val)))
            array.set(binVolumes, binIdx, array.get(binVolumes, binIdx) + barVol)
            if isUp
                array.set(binUpVolumes, binIdx, array.get(binUpVolumes, binIdx) + barVol)
            else
                array.set(binDownVolumes, binIdx, array.get(binDownVolumes, binIdx) + barVol)
        else
            for j = 0 to rowsInput - 1
                float binMin = lo + j * step_val
                float binMax = binMin + step_val
                float overlapMin = math.max(barLow, binMin)
                float overlapMax = math.min(barHigh, binMax)
                
                if overlapMax > overlapMin
                    float proportion = (overlapMax - overlapMin) / (barHigh - barLow)
                    float allocatedVol = barVol * proportion
                    array.set(binVolumes, j, array.get(binVolumes, j) + allocatedVol)
                    if isUp
                        array.set(binUpVolumes, j, array.get(binUpVolumes, j) + allocatedVol)
                    else
                        array.set(binDownVolumes, j, array.get(binDownVolumes, j) + allocatedVol)

    float maxVol = 0.0
    int pocBinIdx = 0
    for j = 0 to rowsInput - 1
        float v = array.get(binVolumes, j)
        if v > maxVol
            maxVol := v
            pocBinIdx := j

    if maxVol == 0
        maxVol := 1.0

    float pocPrice = lo + pocBinIdx * step_val + (step_val / 2.0)
    float hvnThresholdVal = maxVol * (hvnThresh / 100.0)

    if array.size(profileBoxes) > 0
        for b in profileBoxes
            box.delete(b)
        array.clear(profileBoxes)

    int baseRight = bar_index + offsetInput
    for j = 0 to rowsInput - 1
        float v = array.get(binVolumes, j)
        if v == 0
            continue
            
        float upVol = array.get(binUpVolumes, j)
        float downVol = array.get(binDownVolumes, j)
        
        int totalWidth = math.round(widthInput * (v / maxVol))
        int upWidth = math.round(widthInput * (upVol / maxVol))
        
        float binBottom = lo + j * step_val
        float binTop = binBottom + step_val
        
        bool isHVN = v >= hvnThresholdVal
        
        color currentUpColor = isHVN ? hvnUpColor : upColor
        color currentDownColor = isHVN ? hvnDownColor : downColor
        
        int downLeft = baseRight - totalWidth
        box downBox = box.new(
             left=downLeft, top=binTop,
             right=baseRight, bottom=binBottom,
             bgcolor=currentDownColor, border_color=color.new(color.white, 100),
             border_style=line.style_solid
             )
        array.push(profileBoxes, downBox)
        
        if upWidth > 0
            int upLeft = baseRight - upWidth
            box upBox = box.new(
                 left=upLeft, top=binTop,
                 right=baseRight, bottom=binBottom,
                 bgcolor=currentUpColor, border_color=color.new(color.white, 100),
                 border_style=line.style_solid
                 )
            array.push(profileBoxes, upBox)

    if showFixedPOC
        if not na(fixedPocLine)
            line.delete(fixedPocLine)
        fixedPocLine := line.new(
             x1=startBarIndex, y1=pocPrice,
             x2=baseRight, y2=pocPrice,
             color=fixedPocCol, width=2, style=line.style_solid
             )

// =============================================================================
// RESULTS DASHBOARD
// =============================================================================
var float first_bar_time = na
if bar_index == 0
    first_bar_time := time

var table resTable = na
if (barstate.islastconfirmedhistory or barstate.islast) and showDash
    tablePos = dashLoc == "top_right" ? position.top_right :
               dashLoc == "top_left" ? position.top_left :
               dashLoc == "bottom_right" ? position.bottom_right :
               position.bottom_left
               
    if na(resTable)
        resTable := table.new(position=tablePos, columns=2, rows=12, bgcolor=color.new(#16163a, 0), border_color=color.new(#2a2a4a, 0), border_width=1)
    
    int totTrades = array.size(trade_profits)
    int wins = 0
    float netProfit = 0.0
    float grossWins = 0.0
    float grossLosses = 0.0
    float maxGain = 0.0
    float maxLoss = 0.0
    
    float maxDD = 0.0
    float peak = 0.0
    float current_equity = 0.0
    
    if totTrades > 0
        for i = 0 to totTrades - 1
            float p = array.get(trade_profits, i)
            netProfit += p
            current_equity += p
            
            if p > 0
                wins += 1
                grossWins += p
            else
                grossLosses += math.abs(p)
                
            if p > maxGain
                maxGain := p
            if p < maxLoss
                maxLoss := p
                
            if current_equity > peak
                peak := current_equity
            float dd = peak - current_equity
            if dd > maxDD
                maxDD := dd
                
    float winRate = totTrades > 0 ? (wins / totTrades) * 100 : 0
    float pf = grossLosses == 0 ? (grossWins > 0 ? 999.9 : 0.0) : grossWins / grossLosses
    float expect = totTrades > 0 ? netProfit / totTrades : 0
    
    float elapsedDays = (time - nz(first_bar_time, time[1])) / 86400000
    if elapsedDays == 0
        elapsedDays := 1
        
    float tradesPerDay = totTrades / elapsedDays
    float avgMonthly = (netProfit / elapsedDays) * 30.44
    
    float maxDD_val = maxDD
    
    color bgTitle = color.new(#12122a, 0)
    color bgCell = color.new(#16163a, 0)
    color textKey = color.new(#aaaacc, 0)
    color colGreen = color.new(#00c853, 0)
    color colRed = color.new(#ff1744, 0)
    
    string tSize = dashSize == "Tiny" ? size.tiny : dashSize == "Small" ? size.small : dashSize == "Normal" ? size.normal : dashSize == "Large" ? size.large : size.auto
    
    table.cell(resTable, 0, 0, "📊 Strategy Results 📊", text_color=color.white, text_size=tSize, bgcolor=bgTitle)
    table.merge_cells(resTable, 0, 0, 1, 0)
    
    color wrCol = winRate >= 50 ? colGreen : colRed
    table.cell(resTable, 0, 1, "Win Rate", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 1, str.tostring(winRate, "#.##") + "% (" + str.tostring(wins) + "/" + str.tostring(totTrades) + ")", text_color=wrCol, text_size=tSize, bgcolor=bgCell)

    color npCol = netProfit >= 0 ? colGreen : colRed
    string npPrefix = netProfit >= 0 ? "+$" : "-$"
    table.cell(resTable, 0, 2, "Net Profit", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 2, npPrefix + str.tostring(math.abs(netProfit), "#.##"), text_color=npCol, text_size=tSize, bgcolor=bgCell)

    color pfCol = pf >= 1.5 ? colGreen : (pf >= 1.0 ? color.white : colRed)
    string pfText = pf >= 999.0 ? "∞" : str.tostring(pf, "#.##")
    table.cell(resTable, 0, 3, "Profit Factor", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 3, pfText, text_color=pfCol, text_size=tSize, bgcolor=bgCell)

    color expCol = expect >= 0 ? colGreen : colRed
    string expPrefix = expect >= 0 ? "+$" : "-$"
    table.cell(resTable, 0, 4, "Expectancy", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 4, expPrefix + str.tostring(math.abs(expect), "#.##"), text_color=expCol, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 5, "Trades / Day", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 5, str.tostring(tradesPerDay, "#.##"), text_color=color.white, text_size=tSize, bgcolor=bgCell)

    color avgCol = avgMonthly >= 0 ? colGreen : colRed
    string avgPrefix = avgMonthly >= 0 ? "+$" : "-$"
    table.cell(resTable, 0, 6, "Avg Monthly", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 6, avgPrefix + str.tostring(math.abs(avgMonthly), "#.##"), text_color=avgCol, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 7, "Target R:R", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 7, "1 : " + str.tostring(targetRR), text_color=color.white, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 8, "Max Gain", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 8, "+$" + str.tostring(maxGain, "#.##"), text_color=colGreen, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 9, "Max Loss", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 9, "-$" + str.tostring(math.abs(maxLoss), "#.##"), text_color=colRed, text_size=tSize, bgcolor=bgCell)

    table.cell(resTable, 0, 10, "Max Drawdown", text_color=textKey, text_size=tSize, bgcolor=bgCell)
    table.cell(resTable, 1, 10, "-$" + str.tostring(math.abs(maxDD), "#.##"), text_color=colRed, text_size=tSize, bgcolor=bgCell)
